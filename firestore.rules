rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is supervisor
    function isSupervisor() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Supervisor';
    }

    // Helper function to check if user is accountant
    function isAccountant() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Accountant';
    }

    // Supervisor OR Accountant
    function isSupervisorOrAccountant() {
      return isSupervisor() || isAccountant();
    }
    
    // Allow authenticated users to read employees for registration
    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null; // Allow updating email during registration
      allow create, delete: if false; // Only backend can create/delete
    }
    
    // Allow authenticated users to read any user document (needed for duplicate-check query during registration)
    // Write restricted to own document; supervisors may delete any user doc (registration reset)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && (request.auth.uid == userId || isSupervisor());
    }
    
    // Allow authenticated users to read projects, customers
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && isSupervisor();
      allow create, delete: if false;
    }
    
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Time attendance requests and records - users can read their own, supervisors can read all
    match /timeAttendanceRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Only backend can update/delete
    }
    
    match /timeAttendance/{recordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Allow authenticated users to edit
      allow delete: if false; // Only backend can delete
    }
    
    // Financial transactions - supervisors and accountants can read
    match /financialTransactions/{transactionId} {
      allow read: if request.auth != null && isSupervisorOrAccountant();
      allow write: if false; // Only backend can create/update/delete
    }
    
    // Settings - supervisors can read/write
    match /settings/{settingId} {
      allow read: if request.auth != null && isSupervisor();
      allow write: if request.auth != null && isSupervisor();
    }
    
    // Warehouse - supervisors can read/write
    match /warehouse/{itemId} {
      allow read: if request.auth != null && isSupervisor();
      allow write: if false; // Only backend can create/update/delete
    }
    
    // Warehouse transactions - supervisors can read/write
    match /warehouseTransactions/{transactionId} {
      allow read: if request.auth != null && isSupervisor();
      allow write: if false; // Only backend can create/update/delete
    }
    
    // Warehouse requests - employees can read their own and create, supervisors can read all
    match /warehouseRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Only backend can approve/reject/delete
    }
    
    // Legacy time attendance - users can read their own, supervisors can read all
    match /time_attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Only backend can update/delete
    }

    // Salary periods - supervisors read; only backend can write
    match /salaryPeriods/{periodId} {
      allow read: if request.auth != null && isSupervisor();
      allow write: if false;
    }

    // Calculated salaries - supervisors/accountants write; all auth users read (employee page access)
    match /salaries/{salaryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSupervisorOrAccountant();
    }

    // Salary adjustments - supervisors and accountants read/write
    match /salaryAdjustments/{adjId} {
      allow read: if request.auth != null && isSupervisorOrAccountant();
      allow write: if request.auth != null && isSupervisorOrAccountant();
    }

    // Confirmed salaries — two-step approval; immutable once fullyConfirmed
    match /confirmedSalaries/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isSupervisorOrAccountant();
      allow update: if request.auth != null && isSupervisorOrAccountant()
                    && resource.data.fullyConfirmed == false;
      allow delete: if false;
    }

    // Bounty calculations — supervisors/accountants write; all auth users read (employee page access)
    match /bountyCalculations/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSupervisorOrAccountant();
    }

    // Bounty adjustments (manual add/deduct per employee per pay period)
    match /bountyAdjustments/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSupervisorOrAccountant();
    }

    // Confirmed bounties — two-step approval; immutable once fullyConfirmed
    match /confirmedBounties/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isSupervisorOrAccountant();
      allow update: if request.auth != null && isSupervisorOrAccountant()
                    && resource.data.fullyConfirmed == false;
      allow delete: if false;
    }

    // Employee recurring/installment deductions — supervisors manage; all auth read (salary calc)
    match /employeeDeductions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isSupervisorOrAccountant();
      allow update: if request.auth != null && isSupervisorOrAccountant();
      allow delete: if request.auth != null && isSupervisorOrAccountant();
    }

    // Management Goals — supervisors and accountants can read/write
    match /managementGoals/{goalId} {
      allow read: if request.auth != null && isSupervisorOrAccountant();
      allow create, update, delete: if request.auth != null && isSupervisorOrAccountant();
    }
  }
}